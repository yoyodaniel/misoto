rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userUpdateTouchesOnly(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, delete: if isOwner(userId);
      // Block client writes to usage counters and premium flag (server / Admin SDK only).
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['usage', 'premiumUser']);
      allow update: if isSignedIn() && userUpdateTouchesOnly(['followerCount']);
      allow update: if isSignedIn() && userUpdateTouchesOnly(['likesCount']);
      allow update: if isSignedIn() && userUpdateTouchesOnly(['reportCount', 'updatedAt']);
      allow update: if isSignedIn() && userUpdateTouchesOnly(['reportCount', 'isBanned', 'updatedAt']);

      match /devices/{deviceId} {
        allow read, create, update, delete: if isOwner(userId);
      }
    }

    match /recipes/{recipeId} {
      allow read: if (!('isPrivate' in resource.data) || resource.data.isPrivate == false)
        && (!('isHidden' in resource.data) || resource.data.isHidden == false)
        && (!('reportCount' in resource.data) || resource.data.reportCount < 10);
      allow read: if isSignedIn() && resource.data.authorID == request.auth.uid;
      allow read: if isSignedIn()
        && ('isPrivate' in resource.data && resource.data.isPrivate == true)
        && ('sharedWith' in resource.data && request.auth.uid in resource.data.sharedWith);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.authorID == request.auth.uid;
      allow update: if isSignedIn() && userUpdateTouchesOnly(['favoriteCount']);
      allow update: if isSignedIn() && userUpdateTouchesOnly(['reportCount', 'updatedAt']);
      allow update: if isSignedIn() && userUpdateTouchesOnly(['reportCount', 'isHidden', 'updatedAt']);
    }

    match /favorites/{favoriteId} {
      allow read: if isSignedIn() && resource.data.userID == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userID == request.auth.uid
        && request.resource.data.recipeID is string;
      allow update, delete: if isSignedIn() && resource.data.userID == request.auth.uid;
    }

    match /recipeComments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userID;
    }

    match /recipeChangeProposals/{proposalId} {
      allow read: if isSignedIn()
        && (resource.data.userID == request.auth.uid
          || resource.data.recipeAuthorID == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.userID == request.auth.uid
        && request.resource.data.recipeAuthorID is string
        && request.resource.data.recipeAuthorID != request.auth.uid
        && request.resource.data.recipeID is string;
      allow update, delete: if false;
    }

    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.followerID == request.auth.uid;
      allow delete: if isSignedIn()
        && (resource.data.followerID == request.auth.uid
          || resource.data.followingID == request.auth.uid);
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn() && request.resource.data.userID == request.auth.uid;
      allow read: if false;
    }

    match /recipeNotes/{noteId} {
      allow create: if isSignedIn() && request.resource.data.userID == request.auth.uid;
      allow read: if isSignedIn();
      allow update: if isSignedIn()
        && resource.data.userID == request.auth.uid
        && request.resource.data.userID == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userID == request.auth.uid;
    }

    match /recipeReports/{reportId} {
      allow read: if isSignedIn() && resource.data.reporterID == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.reporterID == request.auth.uid
        && request.resource.data.recipeID is string
        && request.resource.data.reason is string
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }

    match /userReports/{reportId} {
      allow read: if isSignedIn() && resource.data.reporterID == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.reporterID == request.auth.uid
        && request.resource.data.reportedUserID is string
        && request.resource.data.reason is string
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }

    // Subscriptions — read own; writes only via Cloud Functions (Admin SDK).
    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /recipeShares/{shareId} {
      allow read: if isSignedIn() && resource.data.userID == request.auth.uid;
      allow read: if isSignedIn() && resource.data.sharedBy == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.sharedBy == request.auth.uid
        && request.resource.data.recipeID is string
        && request.resource.data.userID is string;
      allow delete: if isSignedIn() && resource.data.sharedBy == request.auth.uid;
      allow update: if false;
    }

    match /userProgress/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    // XP ledger — Cloud Functions only.
    match /xpEvents/{eventId} {
      allow read: if false;
      allow write: if false;
    }

    // AI rate limits — Cloud Functions only.
    match /aiRateLimits/{userId} {
      allow read, write: if false;
    }
  }
}
