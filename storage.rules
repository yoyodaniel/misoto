rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isImageUpload() {
      return request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    function isVideoUpload() {
      return request.resource.size < 100 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    // Profile images — users can manage only their own file
    match /profile_images/{fileName} {
      allow read: if isSignedIn();
      allow write, delete: if isSignedIn()
        && fileName.matches(request.auth.uid + '\\.jpg')
        && isImageUpload();
    }

    // User-scoped uploads (current app paths)
    match /users/{userId}/recipes/{fileName} {
      allow read: if isSignedIn();
      allow write, delete: if isOwner(userId) && isImageUpload();
    }

    match /users/{userId}/recipe-instructions/{fileName} {
      allow read: if isSignedIn();
      allow write, delete: if isOwner(userId)
        && (isImageUpload() || isVideoUpload());
    }

    match /users/{userId}/instructions/{fileName} {
      allow read: if isSignedIn();
      allow write, delete: if isOwner(userId) && isImageUpload();
    }

    match /users/{userId}/source-images/{fileName} {
      allow read: if isSignedIn();
      allow write, delete: if isOwner(userId) && isImageUpload();
    }

    // Legacy paths — read existing content; block new writes
    match /recipe_images/{allPaths=**} {
      allow read: if isSignedIn();
      allow write, delete: if false;
    }

    match /recipes/{allPaths=**} {
      allow read: if isSignedIn();
      allow write, delete: if false;
    }

    match /instruction_media/{allPaths=**} {
      allow read: if isSignedIn();
      allow write, delete: if false;
    }

    match /recipe-instructions/{allPaths=**} {
      allow read: if isSignedIn();
      allow write, delete: if false;
    }

    match /instructions/{allPaths=**} {
      allow read: if isSignedIn();
      allow write, delete: if false;
    }

    match /source-images/{allPaths=**} {
      allow read: if isSignedIn();
      allow write, delete: if false;
    }
  }
}
